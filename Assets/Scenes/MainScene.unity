      propertyPath: dialogueEntries.Array.data[19].words.Array.data[0].word
      value: "Mais c'est quoi ton probl\xE8me ?"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[20].words.Array.data[0].word
      value: "Qu'est-ce que tu veux dire ?\_"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[20].words.Array.data[1].word
      value: "Ah ! Tiens, cadeau ! C'est un doublon d'un pr\xE9c\xE9dent \xE9v\xE8nement,
        son design est vraiment sympa"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[21].words.Array.data[0].word
      value: "Tu as gagn\xE9 la derni\xE8re fois, on peut pas toujours \xEAtre top
        1"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[22].words.Array.data[0].word
