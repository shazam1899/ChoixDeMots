    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[0].words.Array.data[0].word
      value: Hey !
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[1].words.Array.data[0].word
      value: "Hey, \xE7a va?"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[2].words.Array.data[0].word
      value: Bien et toi ?
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[4].words.Array.data[0].word
      value: "Cool, tu penses quoi du nouvel \xE9v\xE8nement ?"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[5].words.Array.data[0].word
      value: Je trouve que c'est
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[6].words.Array.data[0].word
      value: "Je vois, personnellement j'aime bien collectionner des trucs, trop
        fi\xE8re de la nouvelle r\xE9compense"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[7].words.Array.data[0].word
      value: Ah bon ? Pourquoi ?
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[8].words.Array.data[0].word
      value: Ah bon ? Pourquoi ?
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[8].words.Array.data[2].word
      value: ' ce que tu as fait'
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[9].words.Array.data[0].word
      value: "C'\xE9tait "
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[9].words.Array.data[1].word
      value: 
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[9].words.Array.data[2].word
      value: ' ce que tu as fait'
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[9].words.Array.data[3].word
      value: ' ce que tu as fait'
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[10].words.Array.data[0].word
      value: "Merci ! Je passe trop de temps \xE0 jouer \xE0 ces jeux sur mon t\xE9l\xE9phone,
        \xE7a m'a bien servi. Je peux t'en recommander quelques-uns si tu veux"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[10].words.Array.data[1].word
      value: Je peux t'en recommander quelques-uns si tu veux
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[11].words.Array.data[0].word
      value: "Ahah tu as le seum ! Mais t'inqui\xE8te, l'\xE9v\xE9nement est pas
        pr\xE8s de se terminer, tu peux toujours r\xE9cup\xE9rer cette r\xE9compense
        en relan\xE7ant une partie"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[12].words.Array.data[0].word
      value: 'Tu '
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[13].words.Array.data[0].word
      value: "Merci, merci, c'est parce que mon adversaire \xE9tait trop cool, je
        devais me montrer \xE0 la hauteur"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[14].words.Array.data[0].word
      value: "La chance est une forme de skill ahah, c'est sympa de faire des matchs
        amicaux comme \xE7a"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[15].words.Array.data[0].word
      value: 'Je pense que tu '
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[15].words.Array.data[2].word
      value: 
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[15].words.Array.data[3].word
      value: 
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[15].words.Array.data[4].word
      value: 'pour '
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[16].words.Array.data[0].word
      value: "C'est \xE7a, c'est \xE7a, le chien aboie mais ne mord pas"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[17].words.Array.data[0].word
      value: ... Okay
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[17].words.Array.data[2].word
      value: 'pour '
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[18].words.Array.data[0].word
      value: "Merci. Ah ! Tiens, cadeau ! C'est un doublon d'un pr\xE9c\xE9dent \xE9v\xE8nement,
        son design est vraiment sympa"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[18].words.Array.data[2].word
      value: 'pour '
      objectReference: {fileID: 0}
