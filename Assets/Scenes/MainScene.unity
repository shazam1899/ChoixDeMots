      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[51].words.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[52].words.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[0].words.Array.data[0].word
      value: Salut, salut
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[1].words.Array.data[0].word
      value: "Salut, \xE7a va ?"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[2].words.Array.data[0].word
      value: "Tu as vraiment bien jou\xE9, je tenais \xE0 te le dire"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[3].words.Array.data[0].word
      value: 'Merci, '
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[4].words.Array.data[0].word
      value: "Ahah, je suis vraiment nul compar\xE9 \xE0 toi, tu pourrais me donner
        quelques conseils ?"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[5].words.Array.data[0].word
      value: 'Je peux te conseiller '
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[6].words.Array.data[0].word
      value: "Wow, tu es un vrai ma\xEEtre Yoda ahah"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[7].words.Array.data[0].word
      value: "J'aime vraiment ce genre d'\xE9v\xE9nement reposant qui permet de se
        poser et de rencontrer plein de gens, comme toi ! "
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[8].words.Array.data[0].word
      value: Un vrai plaisir de te rencontrer
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[9].words.Array.data[0].word
      value: "Je trouve que l'\xE9v\xE9nement "
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[10].words.Array.data[0].word
      value: Je comprends, cela fait combien de temps que tu joues ?
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[12].words.Array.data[0].word
      value: "Tu es un vrai v\xE9t\xE9ran dis donc, je suis vraiment nul \xE0 ce
        jeu mais je pense que jouer avec toi rend l'exp\xE9rience beaucoup plus sympa"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[13].words.Array.data[0].word
      value: "Oh, tu as progress\xE9 rapidement ! Je suis vraiment nul \xE0 ce jeu
        mais je pense que jouer avec toi rend l'exp\xE9rience beaucoup plus sympa"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[14].words.Array.data[0].word
      value: "Tu sais... Je me sens assez seul dans ma vie et je n'ai pas beaucoup
        d'opportunit\xE9s pour rencontrer des gens "
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[15].words.Array.data[0].word
      value: "M\xEAme en essayant de tout mon c\u0153ur, je ne suis pas arriv\xE9
        \xE0 me faire de vrais amis qui me voulaient du bien"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[16].words.Array.data[0].word
      value: Oh,
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[17].words.Array.data[0].word
      value: "Ah, d\xE9sol\xE9 ! Je t'emb\xEAte avec mes affaires, revenons \xE0
        notre sujet, que penses-tu de l'\xE9v\xE9nement ?"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[18].words.Array.data[0].word
      value: "L'\xE9v\xE8nement "
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[19].words.Array.data[0].word
      value: Oh je vois, tu t'es fait d'autres amis ?
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[21].words.Array.data[0].word
      value: "J\u2019ai pas os\xE9 ajouter les autres joueurs, mais j\u2019ai trouv\xE9
        le courage avec toi"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[22].words.Array.data[0].word
      value: 'Ah, '
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[23].words.Array.data[0].word
      value: "Mais maintenant je t'ai toi ! On s'amuse bien ensemble ! Je suis s\xFBr
        qu'une fille comme toi est entour\xE9e de plein de gens"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[24].words.Array.data[0].word
      value: 'Je '
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[25].words.Array.data[0].word
      value: "Ah ! D\xE9sol\xE9, c'est juste que la plupart du temps les autres gar\xE7ons
        ne sont pas sympas, mais tu es vraiment gentil"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[26].words.Array.data[0].word
      value: "Eh bien, je suis content d'\xEAtre l'un de tes meilleurs amis maintenant
        !"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[27].words.Array.data[0].word
      value: Vraiment ? Eh bien, je ferai de mon mieux pour que tu m'aimes bien
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[28].words.Array.data[0].word
      value: "Tu joues souvent \xE0 ce jeu ?"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[30].words.Array.data[0].word
      value: "Mais tes parents ne font pas attention \xE0 toi ?"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[31].words.Array.data[0].word
      value: Tes parents m'ont l'air assez stricts
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[32].words.Array.data[0].word
      value: "J'ai de la chance de plus avoir \xE0 subir la pression de mes parents
        ahah"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[33].words.Array.data[0].word
      value: 'Ils '
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[34].words.Array.data[0].word
      value: "Je trouve que laisser son enfant jouer \xE0 n'importe quel jeu n'est
        pas une super m\xE9thode parentale, les jeux peuvent avoir des contenus violents,
        tu joues \xE0 ce genre de jeu ?"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[36].words.Array.data[0].word
      value: "Fais attention \xE0 toi, tu peux me parler s'il y a un probl\xE8me"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[37].words.Array.data[0].word
      value: "Tu as pris la bonne d\xE9cision"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[38].words.Array.data[0].word
      value: "T'en fais pas je suis l\xE0 pour toi si tu as besoin\L"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[39].words.Array.data[0].word
      value: "Moi aussi, ma famille n'a jamais vraiment \xE9t\xE9 de mon c\xF4t\xE9"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[40].words.Array.data[0].word
      value: Mais quand tu partiras, tout ira mieux, crois-moi
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[41].words.Array.data[0].word
      value: "En parlant de \xE7a, o\xF9 habites-tu ? Comme nous sommes en train
        de jouer \xE0 cette heure dans le m\xEAme serveur, on est s\xFBrement pas
        bien loin l'un de l'autre, ne penses-tu pas ?"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[42].words.Array.data[0].word
      value: 'C''est '
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[43].words.Array.data[0].word
      value: Oh je vois, on habite pas si loin l'un de l'autre ! On peut se voir
        quand tu veux ! Je suis toujours disponible, et j'aimerais bien qu'on se
        rencontre puisqu'on est ami
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[44].words.Array.data[0].word
      value: "Wow, tu habites loin ! Mais bon, on peut se parler en appel vid\xE9o
        aussi, j'adore passer du temps avec toi "
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[45].words.Array.data[0].word
      value: "Je suis toujours disponible pour un appel vid\xE9o, je suis tr\xE8s
        curieux de voir \xE0 quoi tu ressembles"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[46].words.Array.data[0].word
      value: Je comprends, prends ton temps mais j'aimerais bien qu'on se rencontre
        un jour, tu es mon seul ami
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[47].words.Array.data[0].word
      value: "Mais c'est m\xE9chant... pour de vrai cette fois ?"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[48].words.Array.data[0].word
      value: 'C''''est '
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[49].words.Array.data[0].word
      value: Oh je vois, on habite pas si loin l'un de l'autre ! On peut se voir
        quand tu veux ! Je suis toujours disponible, et j'aimerais bien qu'on se
        rencontre puisqu'on est ami
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[50].words.Array.data[0].word
      value: "Wow, tu habites loin ! Mais bon, on peut se parler en appel vid\xE9o
        aussi, j'adore passer du temps avec toi "
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[51].words.Array.data[0].word
      value: "Je suis toujours disponible pour un appel vid\xE9o, je suis tr\xE8s
        curieux de voir \xE0 quoi tu ressembles"
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
      propertyPath: dialogueEntries.Array.data[52].words.Array.data[0].word
      value: Je comprends, prends ton temps mais j'aimerais bien qu'on se rencontre
        un jour, tu es mon seul ami
      objectReference: {fileID: 0}
    - target: {fileID: 2731103165869769011, guid: 447fc4df8f0019941a97b9beecbd2275, type: 3}
